FLASK_ENV=development
FLASK_APP=app.py

# Security
JWT_SECRET_KEY=your-super-secret-key-change-in-production-12345

# Database
DATABASE_URL=sqlite:///stockingvets.db
# For Production PostgreSQL:
# DATABASE_URL=postgresql://username:password@localhost:5432/stockingvets

# Email Configuration (Gmail Example)
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=noreply@stockingvets.io

# Stock API Keys
ALPHA_VANTAGE_KEY=your-alpha-vantage-key
IEX_CLOUD_KEY=your-iex-cloud-key
COINMARKETCAP_KEY=your-coinmarketcap-key

# Social Login
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret

# Application
APP_NAME=StockingVets
APP_URL=http://localhost:3000